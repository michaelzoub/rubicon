# --- Rubicon gateway ---
GATEWAY_PORT=8787
GATEWAY_BASE_URL=http://localhost:8787
# Rubicon meters and charges every word individually. The Rubicon gateway fee is
# zero: creators receive the full word price (minus only unavoidable external
# network/payment-provider costs). Keep this at 0.
GATEWAY_FEE_BPS=0
SESSION_TTL_MS=900000

# --- Published article storage ---
# Required. The gateway reads live articles, creators, sections, and verified
# creator wallets through Supabase.
SUPABASE_URL=https://your-project.supabase.co
# The gateway is a trusted server-side process, so the service-role key is
# accepted and preferred when set — it reads directly, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# An anon/publishable key also works when RLS grants the anon role access:
# SUPABASE_ANON_KEY / SUPABASE_PUBLISHABLE_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY.

# --- Runtime persistence ---
# Optional. When set, the gateway writes stream/word/payment/earnings activity
# to Postgres. Without it, only runtime session state uses an in-memory ledger.
# DATABASE_URL=postgres://user:pass@localhost:5432/rubicon
# Set true to apply migrations on boot (otherwise run `pnpm --filter @rubicon-caliga/gateway migrate`).
RUN_MIGRATIONS=false

# --- Payments ---
# "dev" uses a no-money development verifier; "circle" uses Circle/x402 settlement.
RUBICON_PAYMENTS=dev

# Circle / x402 (Arc Testnet) — only used when RUBICON_PAYMENTS=circle
CIRCLE_CHAIN=arcTestnet
CIRCLE_PRIVATE_KEY=0x...
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
CIRCLE_ARC_PRIVATE_MAINNET=false
# CAIP-2 network string; Arc Testnet chain id is 5042002
CIRCLE_X402_NETWORKS=eip155:5042002
# x402 payment validity window. Circle Gateway requires the buyer authorization's
# validBefore to be >= 7 days out, so leave this unset (defaults to ~7 days) or set
# it >= 604800 — shorter values are rejected by the Arc Testnet Gateway.
# CIRCLE_X402_MAX_TIMEOUT_SECONDS=604900
# Buyer-side RPC for the Gateway client. Optional on Arc testnet.
CIRCLE_RPC_URL=https://rpc.testnet.arc.network
