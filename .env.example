# --- Rubicon gateway ---
# Required. Local development uses the unprefixed variables in this file.
# Staging and production use STAGING_* and PRODUCTION_* resource variables;
# see docs/environments.md for the complete deployed profile contract.
APP_ENV=development
GATEWAY_PORT=8787
GATEWAY_BASE_URL=http://localhost:8787
# Rubicon meters and charges every word individually. The Rubicon gateway fee is
# zero: creators receive the full word price (minus only unavoidable external
# network/payment-provider costs). Keep this at 0.
GATEWAY_FEE_BPS=0
SESSION_TTL_MS=900000

# --- Published article storage ---
# Required. The gateway reads live articles, creators, sections, and verified
# creator wallets through Supabase.
SUPABASE_URL=https://your-project.supabase.co
# The gateway is a trusted server-side process, so the service-role key is
# accepted and preferred when set — it reads directly, bypassing RLS.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# An anon/publishable key also works when RLS grants the anon role access:
# SUPABASE_ANON_KEY / SUPABASE_PUBLISHABLE_KEY / NEXT_PUBLIC_SUPABASE_ANON_KEY.

# --- Runtime persistence (payment ledger) ---
# When set, the gateway writes sessions, authoritative read bundles, optional
# word audits, evidence-backed settlements, and analytics outbox events to Postgres.
# Without it, the ledger is in-memory and nothing is persisted.
#
# Point this at the SAME Supabase Postgres project as SUPABASE_URL above so the
# dashboard reads the live payment ledger (read_bundles, word_deliveries,
# stream_sessions, settlements). Use the connection pooler (IPv4) — the
# direct db.<ref>.supabase.co host is IPv6-only and often unreachable. Use
# `sslmode=no-verify` unless you also configure the Supabase CA certificate.
#
# Supabase Dashboard -> Project Settings -> Database -> Connection string ->
# "Connection pooling" (Session mode, port 5432):
# DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres?sslmode=no-verify
# Set true to apply migrations on boot (otherwise run `pnpm --filter @rubicon-caliga/gateway migrate`).
RUN_MIGRATIONS=false

# --- Optional ClickHouse analytics ---
# ClickHouse is consumed only by the background outbox worker. It is never part
# of content delivery, payment verification, or session correctness.
ANALYTICS_ENABLED=false
# CLICKHOUSE_URL=https://your-clickhouse-host:8443
# CLICKHOUSE_USERNAME=default
# CLICKHOUSE_PASSWORD=...
# CLICKHOUSE_DATABASE=rubicon
ANALYTICS_BATCH_SIZE=500
ANALYTICS_FLUSH_INTERVAL_MS=1000
ANALYTICS_MAX_ATTEMPTS=12
ANALYTICS_LEASE_TIMEOUT_MS=60000

# --- Payments ---
# "dev" uses a no-money development verifier; "circle" uses Circle/x402 settlement.
RUBICON_PAYMENTS=dev

# Deployed profiles require an environment-specific payment provider callback
# URL and secret. They are optional for local no-money development.
# PAYMENT_WEBHOOK_URL=http://localhost:8787/webhooks/payments
# PAYMENT_WEBHOOK_SECRET=local-only-secret

# Circle / x402 (Arc Testnet) — only used when RUBICON_PAYMENTS=circle
CIRCLE_CHAIN=arcTestnet
# Buyer examples use Circle Agent Wallets for real payments. The agent never
# receives or signs with a raw private key.
# CIRCLE_API_KEY=...
# CIRCLE_ENTITY_SECRET=...
# CIRCLE_AGENT_WALLET_ID=...
# Optional, but useful for wallet-alignment checks and avoiding one API lookup:
# CIRCLE_AGENT_WALLET_ADDRESS=0xb161c2306a4f58ca41c4c0b10544d953c8af26b7
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
CIRCLE_ARC_PRIVATE_MAINNET=false
# CAIP-2 network string; Arc Testnet chain id is 5042002
CIRCLE_X402_NETWORKS=eip155:5042002
# x402 payment validity window. Circle Gateway requires the buyer authorization's
# validBefore to be >= 7 days out, so leave this unset (defaults to ~7 days) or set
# it >= 604800 — shorter values are rejected by the Arc Testnet Gateway.
# CIRCLE_X402_MAX_TIMEOUT_SECONDS=604900
# Buyer-side RPC for the Gateway client. Optional on Arc testnet.
# Optional per-user Arc Canteen RPC URL. Keep the token in your local env only.
# CIRCLE_RPC_URL=<local Arc Canteen RPC URL>
