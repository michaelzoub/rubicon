GATEWAY_PORT=8787
GATEWAY_BASE_URL=http://localhost:8787
GATEWAY_FEE_BPS=250
PAYMENT_CHUNK_WORDS=25
PRICE_PER_WORD_ATOMIC=1
DEMO_ARTICLE_ID=rubicon-streaming-001
DEMO_AUTHOR_USERNAME=rubicon-demo
# Optional. If unset, the gateway loads apps/gateway/src/demo-article.md.
DEMO_ARTICLE_CONTENT=
# Comma-separated author registry. Each entry is author_username:arc_wallet_address.
AUTHOR_WALLET_REGISTRY=rubicon-demo:0x...
# Required for POST /v1/seller-agent/navigation.
SELLER_AGENT_API_KEY=dev-seller-agent-key

# Circle / x402 (Arc Testnet)
# chain must be a Circle SupportedChainName (key of GATEWAY_DOMAINS); Arc testnet = "arcTestnet"
CIRCLE_CHAIN=arcTestnet
CIRCLE_PRIVATE_KEY=0x...
# Testnet Gateway/facilitator API (mainnet default is https://gateway-api.circle.com)
CIRCLE_FACILITATOR_URL=https://gateway-api-testnet.circle.com
# Set true only for Circle's Arc mainnet private preview.
CIRCLE_ARC_PRIVATE_MAINNET=false
# CAIP-2 network string; Arc Testnet chain id is 5042002
CIRCLE_X402_NETWORKS=eip155:5042002
# Buyer-side RPC for the Gateway client. Optional on Arc testnet (defaults to
# https://rpc.testnet.arc.network); set to use a custom Arc RPC URL.
CIRCLE_RPC_URL=https://rpc.testnet.arc.network
