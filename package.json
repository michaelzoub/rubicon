{
  "name": "rubicon-x402-streaming-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Gateway and SDKs for metered agent services using x402 nanopayments via Circle Gateway.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:gateway": "pnpm --filter @rubicon/gateway dev",
    "dev:provider": "pnpm --filter @rubicon/mock-provider dev",
    "dev:agent": "pnpm --filter @rubicon/agent-example dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
