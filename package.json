{
  "name": "rubicon-x402-streaming-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Agent SDK and streaming endpoint for x402 article streams charged per word.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:gateway": "pnpm --filter @rubicon-caliga/gateway dev",
    "dev:agent": "pnpm --filter @rubicon-caliga/agent-example dev",
    "dev:cli": "pnpm --filter @rubicon-caliga/cli dev",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "prepare": "husky",
    "smoke:hosted-buyer-flow": "node scripts/smoke-hosted-buyer-flow.mjs"
  },
  "lint-staged": {
    "*.{ts,mts,cts}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.10.2",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.63.0"
  }
}
