{
  "name": "rubicon-x402-streaming-gateway",
  "version": "0.1.0",
  "private": true,
  "description": "Agent SDK and streaming endpoint for x402 article streams charged per word.",
  "type": "module",
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:gateway": "pnpm --filter @rubicon-caliga/gateway dev",
    "dev:agent": "pnpm --filter @rubicon-caliga/agent-example dev",
    "dev:cli": "pnpm --filter @rubicon-caliga/cli dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "smoke:hosted-buyer-flow": "node scripts/smoke-hosted-buyer-flow.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
