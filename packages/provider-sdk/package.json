{
  "name": "@rubicon-caliga/provider-sdk",
  "version": "0.1.0",
  "description": "Provider SDK for compute services exposing metered jobs to the Rubicon x402 streaming gateway.",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelzoub/rubicon.git",
    "directory": "packages/provider-sdk"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test dist/**/*.test.js",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@rubicon-caliga/core": "workspace:*",
    "fastify": "^5.1.0"
  }
}
