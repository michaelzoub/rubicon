{
  "name": "@rubicon-caliga/cli",
  "version": "0.1.3",
  "description": "Terminal-native Rubicon CLI for buyer agents consuming pay-per-word articles.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "rubicon": "dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!dist/**/*.test.*",
    "!src/**/*.test.ts"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michaelzoub/rubicon.git",
    "directory": "packages/cli"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/index.ts",
    "lint": "tsc -p tsconfig.json --noEmit",
    "test": "node --import tsx --test src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@rubicon-caliga/agent-sdk": "0.1.4",
    "@rubicon-caliga/core": "0.1.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
